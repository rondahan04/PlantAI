# Copy to .env and add your Plant.id API key
# Get one at https://plant.id (free tier: 100 requests/month)
EXPO_PUBLIC_PLANTID_API_KEY=your_plantid_api_key_here

# Scraper pipeline keys
EXPO_PUBLIC_FIRECRAWL_API_KEY=your_firecrawl_api_key_here
# GPT-5.5 = extraction + verification critic (OpenAI). Get one at https://platform.openai.com
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here
